    text.BackgroundTransparency = 1
    text.Text = label
    text.TextColor3 = C.TEXT
    text.Font = Enum.Font.GothamMedium
    text.TextSize = 12
    text.TextXAlignment = Enum.TextXAlignment.Left
    
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""

    local pill = Instance.new("Frame", frame)
    pill.Size = UDim2.fromOffset(36, 18)
    pill.Position = UDim2.new(1, -36, 0.5, -9)
    pill.BackgroundColor3 = C.BG
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)
    local iStroke = Instance.new("UIStroke", pill)
    iStroke.Color = C.BORDER
    
    local dot = Instance.new("Frame", pill)
    dot.Size = UDim2.fromOffset(14, 14)
    dot.Position = UDim2.new(0, 2, 0.5, -7)
    dot.BackgroundColor3 = C.MUTED
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local state = default
    local function update()
        TweenService:Create(dot, TweenInfo.new(0.2), {
            Position = UDim2.new(state and 1 or 0, state and -16 or 2, 0.5, -7),
            BackgroundColor3 = state and C.ON_COLOR or C.MUTED
        }):Play()
        TweenService:Create(iStroke, TweenInfo.new(0.2), {
            Color = state and C.ON_COLOR or C.BORDER
        }):Play()
    end
    
    btn.MouseButton1Click:Connect(function()
        state = not state
        update()
        callback(state)
    end)
    update()
end

local function AddSlider(parent, label, minV, maxV, defV, suffix, callback)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, 0, 0, 50)
    frame.BackgroundTransparency = 1

    local sep = Instance.new("Frame", frame)
    sep.Size = UDim2.new(1, -20, 0, 1)
    sep.Position = UDim2.new(0, 10, 1, -1)
    sep.BackgroundColor3 = C.BORDER
    sep.BorderSizePixel = 0

    local text = Instance.new("TextLabel", frame)
    text.Size = UDim2.new(1, -30, 0, 20)
    text.Position = UDim2.new(0, 0, 0, 5)
    text.BackgroundTransparency = 1
    text.Text = label .. ": " .. defV .. suffix
    text.TextColor3 = C.TEXT
    text.Font = Enum.Font.GothamMedium
    text.TextSize = 12
    text.TextXAlignment = Enum.TextXAlignment.Left

    local track = Instance.new("Frame", frame)
    track.Size = UDim2.new(1, -10, 0, 4)
    track.Position = UDim2.new(0, 0, 0, 34)
    track.BackgroundColor3 = C.BG
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    
    local fill = Instance.new("Frame", track)
    fill.BackgroundColor3 = C.ACCENT
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    
    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.fromOffset(12, 12)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local dragging = false
    local function update(posX)
        local rel = math.clamp((posX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = math.floor(minV + rel * (maxV - minV))
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -6, 0.5, -6)
        text.Text = label .. ": " .. val .. suffix
        callback(val)
    end
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = true; update(inp.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
            update(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    local initPct = (defV - minV) / (maxV - minV)
    fill.Size = UDim2.new(initPct, 0, 1, 0)
    knob.Position = UDim2.new(initPct, -6, 0.5, -6)

    return frame
end


local function farmLoop()
    while Flags.FarmActive and Running do
        task.wait(1)
        if not Flags.FarmActive then break end

        if FarmState.firstRun then
            FarmState.firstRun = false
            FarmState.phase = "Kill TP ke Lamont Bell..."
            FarmTiming.batchTimes = {}
            FarmTiming.avgBatchTime = 0
            FarmTiming.currentBatch = 0
            FarmTiming.batchStartTime = nil
            doSuicideTP({name="Lamont Bell", x=510, y=4, z=602})
        end

        FarmState.phase = "Beli bahan di Lamont Bell..."
        local spRE = game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents", 10)
        spRE = spRE and spRE:WaitForChild("StorePurchase", 10)

        if spRE then
            for _, itemName in ipairs({"Gelatin", "Sugar Block Bag", "Water"}) do
                if not Flags.FarmActive then break end
                local have = af_CountBackpack(itemName)
                local need = FarmState.amount - have
                if need <= 0 then continue end
                FarmState.phase = "Beli " .. itemName .. " (" .. have .. "/" .. FarmState.amount .. ")..."
                for i = 1, need do
                    if not Flags.FarmActive then break end
                    if af_CountBackpack(itemName) >= FarmState.amount then break end
                    local added = false
                    local conn; conn = plr.Backpack.ChildAdded:Connect(function(child)
                        if child.Name == itemName then added = true; conn:Disconnect() end
                    end)
                    local t = 0
                    repeat
                        pcall(function() spRE:FireServer(itemName) end)
                        task.wait(0.2); t = t + 0.2
                    until added or t >= 5
                    if not added then pcall(function() conn:Disconnect() end) end
                    task.wait(0.1)
                end
                task.wait(0.3)
            end
        end

        if not Flags.FarmActive then break end
        task.wait(1.5)

        FarmState.phase = "Cek apartment..."
        local House = af_GetHouse()
        if not House then
            local HouseToBuy = af_GetUnclaimedApt()
            if not HouseToBuy then
                repeat task.wait(1); if not Flags.FarmActive then break end
                    FarmState.phase = "Nunggu apt VACANT... coba hop server."
                    HouseToBuy = af_GetUnclaimedApt()
                until HouseToBuy
            end
            if not Flags.FarmActive or not HouseToBuy then break end
            FarmState.phase = "Beli apartment..."
            local bb = HouseToBuy.Board and HouseToBuy.Board:FindFirstChild("backboard")
            if bb then af_TP(bb.CFrame) end
            task.wait(1)
            af_FirePrompt(HouseToBuy.Board:FindFirstChildWhichIsA("ProximityPrompt", true))
            task.wait(1)
            House = af_GetHouse()
        else
            FarmState.phase = "TP ke apartment..."
            local Interior = House:FindFirstChild("Interior") or House
            local Pot = Interior:FindFirstChild("Cooking Pot", true)
            if Pot then
                af_TP(CFrame.new(Pot.Position.X, Pot.Position.Y + 3, Pot.Position.Z))
            else
                local rootPart = House:FindFirstChildOfClass("BasePart")
                if rootPart then af_TP(rootPart.CFrame) end
            end
        end

        if not Flags.FarmActive or not House then break end

        FarmState.phase = "Buka & lock pintu..."
        local PersonalApt = af_GetPersonalApt()
        if PersonalApt and PersonalApt:FindFirstChild("Door") then
            local Door = PersonalApt.Door
            local Interact = Door:FindFirstChild("Interact")
            if Interact then
                local rot = Interact.Rotation
                local isOpen = rot == Vector3.new(0,90,0) or rot == Vector3.new(0,-90,0) or rot == Vector3.new(180,0,180)
                if not isOpen then
                    af_Tween(Interact.CFrame); task.wait(0.5)
                    local openP = Interact:FindFirstChild("Attachment") and Interact.Attachment:FindFirstChildOfClass("ProximityPrompt")
                    if openP then af_FirePrompt(openP) end
                    task.wait(1)
                end
            end
            local DoorLock = Door:FindFirstChild("DoorLock")
            if DoorLock then
                local lockPart = DoorLock:FindFirstChild("Part")
                if lockPart and lockPart.Rotation ~= Vector3.new(90,0,0) then
                    if Interact then af_Tween(Interact.CFrame) end
                    task.wait(0.5)
                    af_FirePrompt(lockPart:FindFirstChildOfClass("ProximityPrompt"))
                    task.wait(0.5)
                end
            end
        end

        if not Flags.FarmActive then break end

        local Interior = House:FindFirstChild("Interior") or House
        local isApt = House.Parent and House.Parent.Name == "Apartments"

        for _, v in pairs(Interior:GetChildren()) do
            if v.Name == "Floor" then pcall(function() v.CanCollide = false end) end
        end

        local Pot = Interior:FindFirstChild("Cooking Pot", true)
        if not Pot then break end

        local PotAttach = Pot:FindFirstChildWhichIsA("Attachment", true)
        local PotPrompt = PotAttach and PotAttach:FindFirstChildOfClass("ProximityPrompt")
                       or Pot:FindFirstChildWhichIsA("ProximityPrompt", true)

        af_Tween(Pot.CFrame)
        if not isApt then af_Tween(Pot.CFrame - Vector3.new(0,7,0)) end

        if FarmState.step == "Sugar Block Bag" then
            repeat task.wait() until Pot.Timer.TextLabel.Text == "0"
            af_Equip("Sugar Block Bag"); task.wait(1)
            af_TweenAndPrompt(Pot, PotPrompt, isApt)
            if not isApt then task.wait(2.5) end
            af_Unequip(); FarmState.step = "Gelatin"
        end

        if FarmState.step == "Gelatin" then
            af_Unequip(); task.wait(1); af_Equip("Gelatin")
            local gelDied = false; local gelConn; gelConn = plr.Character.Humanoid.Died:Connect(function()
                FarmState.step = "Water"; gelDied = true; gelConn:Disconnect()
            end)
            af_TweenAndPrompt(Pot, PotPrompt, isApt)
            if not isApt then task.wait(2.5) end
            FarmState.step = "Collect"; gelConn:Disconnect()
            if gelDied then FarmState.step = "Water" end
        end

        if FarmState.step == "Collect" then
            repeat task.wait() until Pot.Timer.TextLabel.Text == "0"
            local colDied = false; local colConn; colConn = plr.Character.Humanoid.Died:Connect(function()
                FarmState.step = "Water"; colDied = true; colConn:Disconnect()
            end)
            af_Equip("Empty Bag"); task.wait(1)
            af_TweenAndPrompt(Pot, PotPrompt, isApt)
            if not isApt then task.wait(2.5) end
            af_Unequip(); FarmState.step = "Water"; colConn:Disconnect()
        end

        if FarmState.step ~= "Sell" then
            local Water, Gel, Sug = {}, {}, {}
            if plr.Backpack then for _, v in pairs(plr.Backpack:GetChildren()) do
                if v.Name == "Sugar Block Bag" then table.insert(Sug, v)
                elseif v.Name == "Gelatin" then table.insert(Gel, v)
                elseif v.Name == "Water" then table.insert(Water, v) end
            end end

            local highestCommon = math.min(#Water, #Gel, #Sug)

            for i = 1, highestCommon do
                if not Flags.FarmActive then break end

                if FarmTiming.batchStartTime == nil and FarmState.step == "Water" then
                    FarmTiming.batchStartTime = os.clock()
                    FarmTiming.currentBatch = i
                    FarmTiming.totalBatches = FarmState.amount
                end

                if FarmState.step == "Water" then
                    FarmState.phase = "Masak " .. i .. "/" .. FarmState.amount .. " — Water"
                    if not plr.Character:FindFirstChild("Water") then af_Equip("Water") end
                    task.wait(1); af_TweenAndPrompt(Pot, PotPrompt, isApt)
                    if not isApt then task.wait(2.5) end
                    FarmState.step = "Sugar Block Bag"
                end

                if FarmState.step == "Sugar Block Bag" then
                    FarmState.phase = "Masak " .. i .. "/" .. FarmState.amount .. " — Sugar"
                    repeat task.wait() until Pot.Timer.TextLabel.Text == "0"
                    if not plr.Character:FindFirstChild("Sugar Block Bag") then af_Equip("Sugar Block Bag") end
                    task.wait(1); af_TweenAndPrompt(Pot, PotPrompt, isApt)
                    if not isApt then task.wait(2.5) end
                    af_Unequip(); FarmState.step = "Gelatin"
                end

                if FarmState.step == "Gelatin" then
                    FarmState.phase = "Masak " .. i .. "/" .. FarmState.amount .. " — Gelatin"
                    repeat task.wait() until Pot.Timer.TextLabel.Text == "0"
                    local gelDied2 = false; local gelConn2; gelConn2 = plr.Character.Humanoid.Died:Connect(function()
                        FarmState.step = "Water"; gelDied2 = true; gelConn2:Disconnect()
                    end)
                    af_Unequip(); task.wait(1)
                    if not plr.Character:FindFirstChild("Gelatin") then af_Equip("Gelatin") end
                    af_TweenAndPrompt(Pot, PotPrompt, isApt)
                    if not isApt then task.wait(2.5) end
                    FarmState.step = "Collect"; gelConn2:Disconnect()
                    if gelDied2 then break end
                end

                if FarmState.step == "Collect" then
                    FarmState.phase = "Masak " .. i .. "/" .. FarmState.amount .. " — Empty Bag"
                    repeat task.wait() until Pot.Timer.TextLabel.Text == "0"
                    local colDied2 = false; local colConn2; colConn2 = plr.Character.Humanoid.Died:Connect(function()
                        FarmState.step = "Water"; colDied2 = true; colConn2:Disconnect()
                    end)
                    if not plr.Character:FindFirstChild("Empty Bag") then af_Equip("Empty Bag") end
                    task.wait(1); af_TweenAndPrompt(Pot, PotPrompt, isApt)
                    task.wait(1); af_Unequip()
                    FarmState.step = (i == FarmState.amount) and "Sell" or "Water"
                    colConn2:Disconnect()
                    if colDied2 then break end

                    if FarmTiming.batchStartTime then
                        local elapsed = os.clock() - FarmTiming.batchStartTime
                        updateAvgBatchTime(elapsed)
                        FarmTiming.batchStartTime = nil
                    end
                end
            end
        end

        if FarmState.step == "Sell" and Flags.FarmActive then
            FarmState.phase = "Jual Marshmallow ke Lamont Bell..."
            local cashBefore = getMoney() or 0

            af_TP(CFrame.new(510, 4, 602))
            repeat task.wait() until workspace.Folders.NPCs:FindFirstChild("Lamont Bell")
            task.wait(1)
            af_Tween(CFrame.new(511, 4, 598))
            local lamont = workspace.Folders.NPCs:FindFirstChild("Lamont Bell")
            local sellP = lamont and lamont:FindFirstChild("UpperTorso")
                       and lamont.UpperTorso:FindFirstChildOfClass("ProximityPrompt")
            if plr.Backpack and sellP then
                for _, v in pairs(plr.Backpack:GetChildren()) do
                    if not Flags.FarmActive then break end
                    if v:IsA("Tool") and v.Name:find("Marshmallow") then
                        local hum2 = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
                        if hum2 then pcall(function() hum2:EquipTool(v) end) end
                        af_FirePrompt(sellP)
                        FarmState.sold = FarmState.sold + 1
                        task.wait(0.25)
                    end
                end
            end

            -- ── Hitung profit dari sesi jual ini ───────────────
            task.wait(0.5) -- kasih waktu leaderstats update
            local cashAfter = getMoney() or cashBefore
            local gained = cashAfter - cashBefore
            if gained > 0 then
                FarmState.moneyEarned = FarmState.moneyEarned + gained
            end

            FarmState.step = "Water"; FarmState.cycles = FarmState.cycles + 1
            FarmState.phase = "Siklus #" .. FarmState.cycles .. " selesai! Sold: " .. FarmState.sold
            FarmTiming.currentBatch = 0
            FarmTiming.batchStartTime = nil
        end
    end
    Flags.FarmActive = false; FarmState.phase = "STANDBY"
end

local function startFarm()
    if farmThread and coroutine.status(farmThread) ~= "dead" then
        pcall(function() task.cancel(farmThread) end)
    end
    Flags.FarmActive = true
    FarmState.step = "Water"
    FarmState.sold = 0
    FarmState.cycles = 0
    FarmState.firstRun = true
    FarmState.moneyEarned = 0
    FarmTiming.currentBatch = 0
    FarmTiming.batchTimes = {}
    FarmTiming.avgBatchTime = 0
    FarmTiming.batchStartTime = nil
    farmThread = task.spawn(farmLoop)
end

local function stopFarm()
    Flags.FarmActive = false
    if farmThread and coroutine.status(farmThread) ~= "dead" then
        pcall(function() task.cancel(farmThread) end)
    end
    FarmState.step = "Water"
    FarmState.phase = "STANDBY"
end


local FarmState = {
    amount      = 5,
    sold        = 0,
    cycles      = 0,
    step        = "Water",
    firstRun    = true,
    phase       = "STANDBY",
    moneyEarned = 0,   -- total profit terkumpul sejak farm di-on-in
}

local FarmTiming = {
    currentBatch      = 0,
    totalBatches      = FarmState.amount,
    batchStartTime    = nil,
    batchTimes        = {},
    avgBatchTime      = 0,
    sellTimeEstimate  = 6,
}

local function updateAvgBatchTime(newTime)
    table.insert(FarmTiming.batchTimes, newTime)
    local sum = 0
    for _, t in ipairs(FarmTiming.batchTimes) do sum = sum + t end
    FarmTiming.avgBatchTime = sum / #FarmTiming.batchTimes
end

local function getEstimatedTimeRemaining()
    if not Flags.FarmActive then return "N/A" end
    if FarmTiming.avgBatchTime == 0 then
        if FarmTiming.batchStartTime then
            local elapsed = os.clock() - FarmTiming.batchStartTime
            if elapsed > 5 then
                local estBatch = math.max(30, elapsed * 1.5)
                local remainingBatches = math.max(0, FarmState.amount - FarmTiming.currentBatch)
                local totalSec = remainingBatches * estBatch
                local minutes = math.floor(totalSec / 60)
                local seconds = math.floor(totalSec % 60)
                return string.format("~%02d min %02d sec", minutes, seconds)
            end
        end
        return "CALCULATING..."
    end
    local remainingBatches = math.max(0, FarmState.amount - FarmTiming.currentBatch)
    local partial = 0
    if FarmTiming.batchStartTime and FarmTiming.currentBatch > 0 then
        local elapsed = os.clock() - FarmTiming.batchStartTime
        partial = math.max(0, FarmTiming.avgBatchTime - elapsed)
    end
    local totalSec = remainingBatches * FarmTiming.avgBatchTime + partial
    if FarmState.step == "Sell" then totalSec = FarmTiming.sellTimeEstimate end
    totalSec = math.max(0, totalSec)
    local minutes = math.floor(totalSec / 60)
    local seconds = math.floor(totalSec % 60)
    return string.format("%02d min %02d sec", minutes, seconds)
end

